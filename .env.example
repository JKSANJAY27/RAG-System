# ─── Ollama Configuration ──────────────────────────────────────────────────────
# The URL where your local Ollama server runs (default is always this)
OLLAMA_BASE_URL=http://localhost:11434

# The model you pulled with `ollama pull llama3.2:3b`
OLLAMA_MODEL=llama3.2:3b

# ─── ChromaDB Configuration ────────────────────────────────────────────────────
# Where ChromaDB will persist its data on disk
CHROMA_PERSIST_DIR=./chroma_db

# The name of the collection inside ChromaDB (think of it like a table name)
CHROMA_COLLECTION_NAME=rag_documents

# ─── Retrieval Configuration ───────────────────────────────────────────────────
# How many chunks to retrieve for each query (top-k)
TOP_K=5

# ─── Chunking Configuration ────────────────────────────────────────────────────
# Maximum tokens per chunk
CHUNK_SIZE=800

# Token overlap between consecutive chunks (preserves context at boundaries)
CHUNK_OVERLAP=100

# ─── Phase 2: Hybrid Retrieval Configuration ───────────────────────────────────
# Weight between semantic (vector) and keyword (BM25) search (0=BM25, 1=vector)
HYBRID_ALPHA=0.5

# Cross-encoder model for re-ranking (downloads automatically on first run)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# How many chunks to keep after cross-encoder re-ranking
RERANKER_TOP_K=3

# Minimum cross-encoder score to include a chunk (below = decline to answer)
CITATION_SCORE_THRESHOLD=0.1

# ─── Phase 3: Langfuse Observability (optional) ─────────────────────────────────
# Get free keys at https://cloud.langfuse.com
# Leave blank to use the local JSONL fallback (traces/traces.jsonl)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Phase 6: CI Quality Gate Thresholds ───────────────────────────────────────
# Minimum values that the golden eval must hit to pass CI (python evals/run_evals.py --ci)
# Tune these after establishing a baseline — start conservative, tighten over time.
MIN_ANSWER_RATE=0.6         # at least 60% of golden questions must be answered
MIN_MEAN_CONTAINS=0.5       # avg keyword match score across answered questions
MIN_CITATION_RATE=0.7       # at least 70% of answers must cite a source
MIN_MEAN_FAITHFULNESS=0.4   # avg faithfulness (answer grounded in chunks) score
