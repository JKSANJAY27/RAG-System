# ─── Ollama Configuration ──────────────────────────────────────────────────────
# The URL where your local Ollama server runs (default is always this)
OLLAMA_BASE_URL=http://localhost:11434

# The model you pulled with `ollama pull llama3.2:3b`
OLLAMA_MODEL=llama3.2:3b

# ─── ChromaDB Configuration ────────────────────────────────────────────────────
# Where ChromaDB will persist its data on disk
CHROMA_PERSIST_DIR=./chroma_db

# The name of the collection inside ChromaDB (think of it like a table name)
CHROMA_COLLECTION_NAME=rag_documents

# ─── Retrieval Configuration ───────────────────────────────────────────────────
# How many chunks to retrieve for each query (top-k)
TOP_K=5

# ─── Chunking Configuration ────────────────────────────────────────────────────
# Maximum tokens per chunk
CHUNK_SIZE=800

# Token overlap between consecutive chunks (preserves context at boundaries)
CHUNK_OVERLAP=100
